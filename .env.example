# Docker Compose (MySQL)
MYSQL_IMAGE_TAG=8.4
MYSQL_PORT=3306
MYSQL_DATABASE=shophub
MYSQL_USER=shophub
MYSQL_PASSWORD=shophub
MYSQL_ROOT_PASSWORD=root

# Spring Boot datasource
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/shophub?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=shophub
SPRING_DATASOURCE_PASSWORD=shophub
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Redis (auth session store)
REDIS_IMAGE_TAG=7.4-alpine
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2s
APP_AUTH_SESSION_STORE=redis
APP_AUTH_SESSION_TTL_HOURS=24
APP_AUTH_SESSION_KEY_PREFIX=shophub:auth:session:

# MockMap API (reviews + OAuth)
MOCK_MAP_API_BASE_URL=http://localhost:8000
MOCK_MAP_HEALTH_PATH=/health/
MOCK_MAP_OAUTH_TOKEN_PATH=/oauth/token/
MOCK_MAP_REVIEWS_PATH=/api/reviews/
MOCK_MAP_OAUTH_CLIENT_ID=
MOCK_MAP_OAUTH_CLIENT_SECRET=
MOCK_MAP_OAUTH_REFRESH_TOKEN=
MOCK_MAP_OAUTH_REDIRECT_URI=http://localhost:8080/api/integrations/MOCK_MAP/oauth/callback
MOCK_MAP_OAUTH_AUTHORIZE_PATH=/oauth/authorize/
MOCK_MAP_OAUTH_REVOKE_PATH=/oauth/revoke/
MOCK_MAP_OAUTH_TOKEN_STORE_PATH=./.mockmap-oauth-store.json
MOCK_MAP_OAUTH_CACHE_STORE=redis
MOCK_MAP_OAUTH_PENDING_STATE_TTL_SECONDS=600
MOCK_MAP_OAUTH_PENDING_STATE_KEY_PREFIX=shophub:mockmap:oauth:pending-state:
MOCK_MAP_OAUTH_ACCESS_TOKEN_KEY_PREFIX=shophub:mockmap:oauth:access-token:

# OpenAI (ANTHROPIC_API_KEY 없을 때 사용)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# Anthropic Claude (설정 시 OpenAI보다 우선)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_API_VERSION=2023-06-01

# Instagram Graph API (@commentcopybot)
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com/v21.0
INSTAGRAM_GRAPH_ACCOUNT_ID=17841476807685488
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_GRAPH_ALLOWED_ACCOUNT_ID=17841476807685488
INSTAGRAM_GRAPH_ALLOWED_USERNAME=commentcopybot
INSTAGRAM_GRAPH_MAX_ATTEMPTS=15
INSTAGRAM_GRAPH_INTERVAL_MS=2000

# X API (OAuth 2.0 PKCE, store별 계정 연결)
X_TWEETS_URL=https://api.x.com/2/tweets
X_MEDIA_UPLOAD_URL=https://api.x.com/2/media/upload
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://your-subdomain.ngrok-free.dev/api/integrations/X/oauth/callback
X_OAUTH_SCOPE=tweet.read tweet.write users.read offline.access media.write
X_OAUTH_CACHE_STORE=redis
X_OAUTH_PENDING_STATE_TTL_SECONDS=600

# Facebook Graph API (Page Access Token)
FACEBOOK_GRAPH_BASE_URL=https://graph.facebook.com/v21.0
FACEBOOK_GRAPH_PAGE_ID=
FACEBOOK_GRAPH_ACCESS_TOKEN=
FACEBOOK_GRAPH_ALLOWED_PAGE_ID=
FACEBOOK_GRAPH_ALLOWED_PAGE_NAME=

# Local upload/public URL
APP_REVIEW_SOURCE_PROVIDER=mockmap
APP_REVIEW_SYNC_ENABLED=true
APP_REVIEW_SYNC_CRON=0 */5 * * * *
APP_STORAGE_UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:8080
# catbox | public-base-url | picsum-dev (InstarExample과 동일한 picsum URL, 로컬 Instagram 테스트용)
APP_STORAGE_PUBLIC_IMAGE_PROVIDER=picsum-dev
